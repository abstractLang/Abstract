### ABSTRACT STANDARD LIBRARY SCRIPT ###

@public const f64 PI = 3.1415
@public const f64 E = 2.71828

@public func sin(type T, T rad) T
@public func cos(type T, T rad) T
@public func tan(type T, T rad) T

@public func atan(type T, T x) T
@public func atan2(type T, T x, T y) T

@public func sqrt(type T, T value) T

@public func abs(type T, T value) T
@public func ceil(type T, T value) T
@public func floor(type T, T value) T
@public func round(type T, T value) T
@public func truncate(type T, T value) T

@public func deg2rad(type T, T deg) T
@public func rad2deg(type T, T rad) T

@public func log(type T, T val, T base) T
